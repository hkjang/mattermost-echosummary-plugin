{
    "id": "com.mattermost.echosummary",
    "name": "Echo Summary",
    "description": "Summarize each user's previous-day Mattermost conversations with a configurable vLLM OpenAI-compatible API and deliver the report on scheduled times.",
    "homepage_url": "https://github.com/hkjang/mattermost-echosummary-plugin",
    "support_url": "https://github.com/hkjang/mattermost-echosummary-plugin/issues",
    "icon_path": "assets/starter-template-icon.svg",
    "version": "0.6.0",
    "min_server_version": "6.2.1",
    "server": {
        "executables": {
            "linux-amd64": "server/dist/plugin-linux-amd64",
            "linux-arm64": "server/dist/plugin-linux-arm64",
            "darwin-amd64": "server/dist/plugin-darwin-amd64",
            "darwin-arm64": "server/dist/plugin-darwin-arm64",
            "windows-amd64": "server/dist/plugin-windows-amd64.exe"
        }
    },
    "webapp": {
        "bundle_path": "webapp/dist/main.js"
    },
    "settings_schema": {
        "header": "Echo Summary는 전날 사용자가 참여한 대화를 수집해 지정한 vLLM OpenAI 호환 Chat Completions API로 요약하고, 사용자별 시간 슬롯에 맞춰 DM으로 전달합니다.",
        "sections": [
            {
                "key": "vllm",
                "title": "vLLM 요약 설정",
                "settings": [
                    {
                        "key": "VLLMBaseURL",
                        "display_name": "vLLM Base URL",
                        "type": "text",
                        "placeholder": "https://vllm.example.com/v1",
                        "help_text": "루트 URL 또는 /v1 경로까지 넣으면 됩니다. 플러그인이 /chat/completions 경로를 자동으로 맞춰 호출합니다."
                    },
                    {
                        "key": "VLLMAPIKey",
                        "display_name": "vLLM API Key",
                        "type": "text",
                        "placeholder": "sk-...",
                        "help_text": "필요한 경우 Authorization Bearer 토큰으로 전달됩니다.",
                        "secret": true
                    },
                    {
                        "key": "VLLMModel",
                        "display_name": "요약 모델명",
                        "type": "text",
                        "placeholder": "qwen2.5-14b-instruct",
                        "help_text": "Chat Completions 요청의 model 값으로 그대로 전달됩니다."
                    },
                    {
                        "key": "DefaultPrompt",
                        "display_name": "기본 요약 프롬프트",
                        "type": "longtext",
                        "help_text": "system 프롬프트로 사용됩니다. 비워두면 Echo Summary 기본 프롬프트가 적용됩니다."
                    },
                    {
                        "key": "RequestTimeoutSeconds",
                        "display_name": "요약 요청 타임아웃(초)",
                        "type": "number",
                        "default": 60,
                        "help_text": "vLLM 응답을 기다리는 최대 시간입니다."
                    }
                ]
            },
            {
                "key": "scope",
                "title": "대상 사용자와 스케줄",
                "settings": [
                    {
                        "key": "NotificationTimezone",
                        "display_name": "기본 타임존",
                        "type": "text",
                        "default": "Asia/Seoul",
                        "placeholder": "Asia/Seoul",
                        "help_text": "전날 기준일과 사용자 발송 시간 계산에 사용됩니다."
                    },
                    {
                        "key": "DefaultTimeSlots",
                        "display_name": "기본 발송 시간",
                        "type": "text",
                        "default": "09:00",
                        "placeholder": "09:00,13:30",
                        "help_text": "사용자 개인 설정이 없을 때 적용되는 기본 시간 슬롯입니다. 쉼표로 여러 시간을 넣을 수 있습니다."
                    },
                    {
                        "key": "TargetUsernames",
                        "display_name": "대상 사용자 범위",
                        "type": "text",
                        "placeholder": "alice,bob",
                        "help_text": "비워두면 모든 활성 사용자에게 적용합니다. 값을 넣으면 지정한 username만 대상으로 삼습니다."
                    },
                    {
                        "key": "IncludeMentionedThreads",
                        "display_name": "멘션된 thread 포함",
                        "type": "bool",
                        "default": false,
                        "help_text": "사용자가 직접 작성하지 않았더라도 전날 멘션된 thread를 요약 후보에 포함합니다."
                    }
                ]
            },
            {
                "key": "collection",
                "title": "수집 범위",
                "settings": [
                    {
                        "key": "MaxThreadsPerUser",
                        "display_name": "사용자당 최대 스레드 수",
                        "type": "number",
                        "default": 40,
                        "help_text": "너무 많은 참여 대화가 있을 때 최신순으로 이 개수까지만 요약합니다."
                    },
                    {
                        "key": "MaxContextCharacters",
                        "display_name": "요청당 최대 문맥 길이",
                        "type": "number",
                        "default": 12000,
                        "help_text": "수집된 문맥을 여러 Chat Completions 요청으로 나눌 때 사용하는 문자 수 기준입니다."
                    },
                    {
                        "key": "ContextMessagesBefore",
                        "display_name": "anchor 이전 문맥 수",
                        "type": "number",
                        "default": 3,
                        "help_text": "사용자 참여 메시지 앞쪽에서 함께 포함할 최대 메시지 수입니다."
                    },
                    {
                        "key": "ContextMessagesAfter",
                        "display_name": "anchor 이후 문맥 수",
                        "type": "number",
                        "default": 6,
                        "help_text": "사용자 참여 메시지 뒤쪽에서 함께 포함할 최대 메시지 수입니다."
                    }
                ]
            }
        ]
    }
}
